# ============================================
#   SHALA-MINI-BOT - config.env.example
#   Copy this file to config.env and fill in
# ============================================

# --- DATABASE ---
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/
MONGO_DB=shalabot

# --- BOT BASICS ---
PREFIX=.
MAX_RETRIES=5
WORK_TYPE=private

# --- OWNER INFO ---
OWNER_NAME=YourName
OWNER_NUMBER=94XXXXXXXXX
OWNER_NUMBERS=94XXXXXXXXX,94XXXXXXXXX
SUDO_NUMBERS=94XXXXXXXXX

# --- BOT INFO ---
BOT_NAME=*Sʜᴀʟᴀ Mᴅ ᴮᴱᵀᴬ*
BOT_VERSION=1.0.0 Pro

# --- AUTO FEATURES ---
AUTO_AI=true
AUTO_VIEW_STATUS=true
AUTO_LIKE_STATUS=true
AUTO_RECORDING=true
OWNER_REACT=true
AUTO_REPLY=true
LANG=EN

# --- MEDIA / LINKS ---
IMAGE_PATH=https://your-image-url.jpg
CHANNEL_LINK=https://whatsapp.com/channel/YOUR_CHANNEL
GROUP_INVITE_LINK=https://chat.whatsapp.com/YOUR_GROUP

# --- NEWSLETTER ---
NEWSLETTER_JID=120363322195409882@newsletter
NEWSLETTER_MESSAGE_ID=428

# --- MISC ---
OTP_EXPIRY=300000
